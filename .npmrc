# Placeholder registry config for the private @hydra scope. No real registry host or
# auth token is committed in Phase 0 — nothing is published in this slice. When the
# publish path is wired (a later slice), point the scope at the private registry and
# inject the auth token from CI secrets; never commit a token here.
#
# @hydra:registry=https://<private-registry>/
# //<private-registry>/:_authToken=${HYDRA_NPM_TOKEN}

# Keep cross-workspace links resolving to local source during development.
link-workspace-packages=true
